/*
    X-Content-Type-Options: nosniff
    Referrer-Policy: strict-origin
    Content-Security-Policy: default-src 'self'; script-src 'self' https://static.cloudflareinsights.com https://embed.doorbell.io; style-src 'self' https://embed.doorbell.io; connect-src 'self' https://cloudflareinsights.com https://doorbell.io; worker-src blob:; frame-ancestors 'none';

https://:project.pages.dev/*
    X-Robots-Tag: noindex

/js/*
    Cache-Control: max-age=604800
/css/*
    Cache-Control: max-age=604800
/assets/*
    Cache-Control: max-age=604800

/data/*
    Cache-Control: max-age=86400
